// ─── Test & Tag Asset ───────────────────────────────────────────────────────

model TestTagAsset {
  id                 String         @id @default(cuid())
  organizationId     String
  organization       Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  testTagId          String
  description        String
  equipmentClass     EquipmentClass @default(CLASS_I)
  applianceType      ApplianceType  @default(APPLIANCE)
  make               String?
  modelName          String?
  serialNumber       String?
  location           String?
  testIntervalMonths Int            @default(3)
  status             TestTagStatus  @default(NOT_YET_TESTED)
  lastTestDate       DateTime?
  nextDueDate        DateTime?
  notes              String?

  assetId            String?        @unique
  asset              Asset?         @relation(fields: [assetId], references: [id], onDelete: SetNull)
  bulkAssetId        String?
  bulkAsset          BulkAsset?     @relation(fields: [bulkAssetId], references: [id], onDelete: SetNull)

  isActive           Boolean        @default(true)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  testRecords        TestTagRecord[]

  @@unique([organizationId, testTagId])
  @@index([organizationId, status])
  @@index([organizationId, nextDueDate])
  @@index([organizationId, assetId])
  @@index([organizationId, bulkAssetId])
  @@map("test_tag_asset")
}

// ─── Test & Tag Record ──────────────────────────────────────────────────────

model TestTagRecord {
  id                     String         @id @default(cuid())
  organizationId         String
  organization           Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  testTagAssetId         String
  testTagAsset           TestTagAsset   @relation(fields: [testTagAssetId], references: [id], onDelete: Cascade)
  testDate               DateTime
  testedById             String
  testedBy               User           @relation(fields: [testedById], references: [id])
  testerName             String

  result                 TestResult     @default(PASS)

  // Visual inspection
  visualInspectionResult TestResult     @default(PASS)
  visualCordCondition    Boolean?
  visualPlugCondition    Boolean?
  visualHousingCondition Boolean?
  visualSwitchCondition  Boolean?
  visualVentsUnobstructed Boolean?
  visualCordGrip         Boolean?
  visualEarthPin         Boolean?
  visualMarkingsLegible  Boolean?
  visualNoModifications  Boolean?
  visualNotes            String?

  // Electrical tests
  equipmentClassTested   EquipmentClass @default(CLASS_I)
  testMethod             TestMethod     @default(INSULATION_RESISTANCE)

  // Earth continuity (Class I only)
  earthContinuityResult  TestResult     @default(NOT_APPLICABLE)
  earthContinuityReading Float?

  // Insulation resistance
  insulationResult       TestResult     @default(NOT_APPLICABLE)
  insulationReading      Float?
  insulationTestVoltage  Int?

  // Leakage current
  leakageCurrentResult   TestResult     @default(NOT_APPLICABLE)
  leakageCurrentReading  Float?

  // Polarity
  polarityResult         TestResult     @default(NOT_APPLICABLE)

  // RCD trip time
  rcdTripTimeResult      TestResult     @default(NOT_APPLICABLE)
  rcdTripTimeReading     Float?

  // Functional test
  functionalTestResult   TestResult     @default(NOT_APPLICABLE)
  functionalTestNotes    String?

  // Failure actions
  failureAction          FailureAction  @default(NONE)
  failureNotes           String?

  // Next test
  nextDueDate            DateTime

  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt

  @@index([organizationId, testTagAssetId])
  @@index([organizationId, testDate])
  @@map("test_tag_record")
}

// ─── Better Auth Two-Factor Tables ──────────────────────────────────────────

model TwoFactor {
  id            String   @id @default(cuid())
  secret        String
  backupCodes   String
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("twoFactor")
}

model BackupCode {
  id        String   @id @default(cuid())
  code      String
  used      Boolean  @default(false)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@map("backup_code")
}

model Passkey {
  id              String   @id @default(cuid())
  name            String?
  publicKey       String
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  credentialID    String   @unique
  counter         Int
  deviceType      String
  backedUp        Boolean
  transports      String?
  aaguid          String?
  createdAt       DateTime @default(now())

  @@index([userId])
  @@map("passkey")
}

// ─── Site Settings ──────────────────────────────────────────────────────────

model SiteSettings {
  id                     String   @id @default(cuid())
  platformName           String   @default("GearFlow")
  platformIcon           String?  // Lucide icon name, e.g. "clapperboard", "zap"
  platformLogo           String?
  registrationPolicy     String   @default("OPEN") // OPEN, INVITE_ONLY, DISABLED
  twoFactorGlobalPolicy  String   @default("OFF")  // OFF, RECOMMENDED, REQUIRED_SITE_ADMINS, REQUIRED_ALL
  defaultCurrency        String   @default("AUD")
  defaultTaxRate         Float    @default(10)
  socialLoginGoogle      Boolean  @default(false)
  socialLoginMicrosoft   Boolean  @default(false)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@map("site_settings")
}

// ─── Activity Log ────────────────────────────────────────────────────────────

model ActivityLog {
  id              String   @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  action          String   // CREATE, UPDATE, DELETE, STATUS_CHANGE, CHECK_OUT, CHECK_IN, etc.
  entityType      String   // asset, bulkAsset, model, kit, project, client, location, etc.
  entityId        String
  entityName      String   // Human-readable name/tag at time of action

  userId          String?
  user            User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  userName        String   // Denormalized — preserved if user is deleted

  summary         String   // Human-readable: "Created asset TTP-00042"
  details         Json?    // Structured change data
  metadata        Json?    // Extra context

  projectId       String?
  assetId         String?
  kitId           String?

  createdAt       DateTime @default(now())

  @@index([organizationId, createdAt])
  @@index([organizationId, entityType])
  @@index([organizationId, userId])
  @@index([organizationId, projectId])
  @@index([organizationId, assetId])
  @@index([organizationId, entityType, entityId])
  @@map("activity_log")
}

// ─── Crew Management ─────────────────────────────────────────────────────────

model CrewMember {
  id              String   @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Identity
  firstName       String
  lastName        String
  email           String?
  phone           String?
  image           String?

  // Link to platform user (optional)
  userId          String?
  user            User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  // Employment type
  type            CrewMemberType  @default(FREELANCER)
  status          CrewMemberStatus @default(ACTIVE)
  department      String?

  // Rates
  defaultDayRate    Decimal?  @db.Decimal(10, 2)
  defaultHourlyRate Decimal?  @db.Decimal(10, 2)
  overtimeMultiplier Decimal? @db.Decimal(3, 2)
  currency          String?

  // Contact & personal
  address           String?
  addressLatitude   Float?
  addressLongitude  Float?
  emergencyContactName  String?
  emergencyContactPhone String?
  dateOfBirth     DateTime?
  abnOrGst        String?

  // Notes & tags
  notes           String?
  tags            String[] @default([])

  // Relations
  skills          CrewSkill[]
  certifications  CrewCertification[]
  crewRoleId      String?
  crewRole        CrewRole? @relation(fields: [crewRoleId], references: [id], onDelete: SetNull)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  isActive        Boolean  @default(true)

  @@unique([organizationId, email])
  @@index([organizationId])
  @@index([organizationId, status])
  @@index([userId])
  @@map("crew_member")
}

enum CrewMemberType {
  EMPLOYEE
  FREELANCER
  CONTRACTOR
  VOLUNTEER
}

enum CrewMemberStatus {
  ACTIVE
  INACTIVE
  ON_LEAVE
  ARCHIVED
}

model CrewRole {
  id              String   @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name            String
  description     String?
  department      String?
  color           String?
  defaultRate     Decimal? @db.Decimal(10, 2)
  rateType        CrewRateType?
  sortOrder       Int      @default(0)
  isActive        Boolean  @default(true)

  crewMembers     CrewMember[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("crew_role")
}

enum CrewRateType {
  HOURLY
  DAILY
  FLAT
}

model CrewSkill {
  id              String   @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name            String
  category        String?

  crewMembers     CrewMember[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("crew_skill")
}

model CrewCertification {
  id              String   @id @default(cuid())
  crewMemberId    String
  crewMember      CrewMember @relation(fields: [crewMemberId], references: [id], onDelete: Cascade)

  name            String
  issuedBy        String?
  certificateNumber String?
  issuedDate      DateTime?
  expiryDate      DateTime?
  status          CrewCertStatus @default(NOT_VERIFIED)

  @@index([crewMemberId])
  @@map("crew_certification")
}

enum CrewCertStatus {
  CURRENT
  EXPIRING_SOON
  EXPIRED
  NOT_VERIFIED
}
