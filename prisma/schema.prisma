  sortOrder      Int          @default(0)
  createdAt      DateTime     @default(now())

  @@unique([assetId, fileId])
  @@index([organizationId])
  @@index([assetId])
  @@map("asset_media")
}

model KitMedia {
  id             String       @id @default(cuid())
